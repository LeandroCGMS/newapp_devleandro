{
  "expo": {
    "name": "newapp_devleandro",
    "slug": "newapp_devleandro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "newappdevleandro",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/my-logo.png", //android-icon-foreground.png
        "backgroundImage": "./assets/images/my-logo.png",
        "monochromeImage": "./assets/images/my-logo.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.INTERNET"
      ],
      "package": "com.lecgms.newapp_devleandro"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/my-logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "image": "./assets/images/my-logo.png",
          "imageWidth": 76
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7a86b138-2c97-41db-8edc-211455805bc3"
      }
    }
  }
}
